  {
    "compilerOptions": {
      "ignoreDeprecations": "5.0",
      "allowSyntheticDefaultImports": true,
      "declaration": true,
      "emitDecoratorMetadata": true,
      "esModuleInterop": true,
      "experimentalDecorators": true,
      "forceConsistentCasingInFileNames": true,
      "incremental": true,
      "isolatedModules": true,
      "module": "CommonJS",
      "moduleResolution": "Node",
      "noFallthroughCasesInSwitch": false,
      "outDir": "./dist",
      "baseUrl": "./",
      "paths": {
        "@/*": [
          "src/*"
        ],
        "@/shared/*": [
          "src/shared/*"
        ],
        "@/types/*": [
          "src/types/*"
        ],
        "@/modules/*": [
          "src/modules/*"
        ],
        "@/services/*": [
          "src/services/*"
        ],
        "@/config/*": [
          "src/config/*"
        ],
        "@/core/*": [
          "src/core/*"
        ]
      },
      "removeComments": true,
      "skipLibCheck": true,
      "sourceMap": true,
      "strictBindCallApply": false,
      "noImplicitAny": false,
      "strictNullChecks": false,
      "target": "es2022",
      "typeRoots": [
        "./node_modules/@types"
      ],
      "types": [
        "node",
        "multer",
        "jest"
      ],
      "allowImportingTsExtensions": false,
      "noEmit": false
    },
    "exclude": [
      "node_modules",
      "dist"
    ],
    "include": [
      "src/**/*",
      "test/**/*",
      "src/scripts/generate-structure.ts"
    ]
  }