# Application Configuration
NODE_ENV=development
PORT=3400
FAST_STARTUP=false
FRONTEND_URLS=http://localhost:3000,http://localhost:3001

# Database Configuration
MONGO_HOST=localhost
MONGO_DB=apac-db
MONGO_USER=admin
MONGO_PASS=password
# Optional: Full Connection String (overrides individual fields)
# DATABASE_URL=mongodb://admin:password@localhost:27017/apac-db

# Security
JWT_SECRET=your-secure-jwt-secret-key-must-be-at-least-32-chars-long

# Google Cloud Storage (GCS)
GCS_BUCKET_NAME=your-bucket-name
GCS_PROJECT_ID=your-project-id
# Option 1: Path to JSON key file
GOOGLE_APPLICATION_CREDENTIALS=./gcs-key.json
# Option 2: JSON content as string
# GCS_KEY_JSON={"type": "service_account", ...}

# AI Configuration
AI_ENABLED=false
OPENAI_API_KEY=sk-your-openai-api-key-here
AI_MODEL=gpt-4-turbo-preview
AI_TEMPERATURE=0.7
AI_MAX_TOKENS=1000
# Optional: Anthropic Claude
# ANTHROPIC_API_KEY=sk-ant-your-anthropic-key-here
# Optional: Vector Database (for future RAG features)
# PINECONE_API_KEY=your-pinecone-key
# PINECONE_ENVIRONMENT=us-west1-gcp
# PINECONE_INDEX_NAME=apac-leave-requests
