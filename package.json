{
    "name": "apac-management-system",
    "version": "1.0.0",
    "private": true,
    "description": "APAC HR Management System: A next-generation platform for comprehensive workforce management, including leave, self-service, analytics, and performance, built with a scalable microservices architecture for enhanced HR operations.",
    "license": "MicroAgility",
    "author": "MicroAgility - Solutions Delivery Team",
    "scripts": {
        "build": "nest build",
        "type-check": "tsc --noEmit --skipLibCheck",
        "start": "nest start",
        "start:dev": "nest start --watch",
        "start:prod": "node dist/main",
        "dev": "npm run start:dev",
        "test": "jest",
        "test:watch": "jest --watch",
        "test:cov": "jest --coverage",
        "test:unit": "jest --testPathPattern=\"unit\" --coverage",
        "test:integration": "jest --testPathPattern=\"integration\" --detectOpenHandles",
        "test:e2e": "jest --testPathPattern=\"e2e\" --detectOpenHandles --forceExit",
        "test:ci": "jest --coverage --ci --watchAll=false --runInBand --detectOpenHandles",
        "lint": "eslint \"src/**/*.ts\" --fix",
        "lint:check": "eslint \"src/**/*.ts\"",
        "fix": "prettier --write \"src/**/*.{ts,js,json,html,md,yml,yaml}\" \"test/**/*.{ts,js,json,html,md,yml,yaml}\"",
        "fix:check": "prettier --check \"src/**/*.{ts,js,json,html,md,yml,yaml}\" \"test/**/*.{ts,js,json,html,md,yml,yaml}\"",
        "deps:audit": "npm audit --audit-level=high || true",
        "deps:update": "npm update",
        "clean": "rmdir /s /q node_modules dist 2>nul & del package-lock.json 2>nul & del coverage 2>nul & del dist 2>nul",
        "reinstall": "npm run clean && npm install",
        "preflight": "npm run lint && npm run type-check",
        "g-s": "node src/scripts/generate-structure.ts"
    },
    "dependencies": {
        "@google-cloud/storage": "^7.18.0",
        "@nestjs/axios": "^4.0.1",
        "@nestjs/cache-manager": "^3.1.0",
        "@nestjs/common": "^11.1.10",
        "@nestjs/config": "^4.0.2",
        "@nestjs/core": "^11.1.10",
        "@nestjs/jwt": "^11.0.2",
        "@nestjs/mongoose": "^11.0.4",
        "@nestjs/passport": "^11.0.5",
        "@nestjs/platform-express": "^11.1.10",
        "@nestjs/serve-static": "^5.0.4",
        "@nestjs/swagger": "^11.2.3",
        "@nestjs/terminus": "^11.0.0",
        "@nestjs/throttler": "^6.5.0",
        "axios": "^1.13.2",
        "bcrypt": "^6.0.0",
        "cache-manager": "^7.2.7",
        "class-transformer": "^0.5.1",
        "class-validator": "^0.14.3",
        "compression": "^1.8.1",
        "dotenv": "^17.2.3",
        "emittery": "^1.2.0",
        "exceljs": "^4.4.0",
        "execa": "^9.6.1",
        "express": "^5.2.1",
        "express-rate-limit": "^8.2.1",
        "handlebars": "^4.7.8",
        "helmet": "^8.1.0",
        "langchain": "^1.2.3",
        "mime-types": "^3.0.2",
        "multer": "^2.0.2",
        "npm": "^11.7.0",
        "passport": "^0.7.0",
        "passport-jwt": "^4.0.1",
        "reflect-metadata": "^0.2.2",
        "rxjs": "^7.8.2",
        "sparse-bitfield": "^3.0.3",
        "swagger-jsdoc": "^6.2.8",
        "swagger-ui-express": "^5.0.1",
        "uuid": "^10.0.0",
        "xlsx": "^0.18.5"
    },
    "devDependencies": {
        "@nestjs/cli": "^11.0.14",
        "@nestjs/testing": "^11.1.11",
        "@types/bcrypt": "^6.0.0",
        "@types/cache-manager": "^5.0.0",
        "@types/compression": "^1.8.1",
        "@types/express": "^5.0.6",
        "@types/jest": "^30.0.0",
        "@types/multer": "^2.0.0",
        "@types/node": "^25.0.3",
        "@types/passport-jwt": "^4.0.1",
        "@types/supertest": "^6.0.3",
        "@types/uuid": "^10.0.0",
        "@typescript-eslint/eslint-plugin": "8.46.2",
        "@typescript-eslint/parser": "8.46.2",
        "depcheck": "^1.4.7",
        "eslint": "^8.57.0",
        "eslint-config-prettier": "^10.1.8",
        "eslint-import-resolver-typescript": "^4.4.4",
        "eslint-plugin-import": "2.32.0",
        "eslint-plugin-prettier": "^5.5.4",
        "eslint-plugin-simple-import-sort": "12.1.1",
        "eslint-plugin-unused-imports": "4.3.0",
        "jest": "^29.7.0",
        "jest-html-reporters": "^3.1.5",
        "jest-junit": "^16.0.0",
        "jest-util": "^30.2.0",
        "mongodb-memory-server": "^11.0.1",
        "mongoose": "9.0.2",
        "prettier": "^3.7.4",
        "supertest": "^7.1.4",
        "ts-jest": "^29.1.2",
        "ts-loader": "^9.5.4",
        "ts-node": "^1.7.1",
        "ts-prune": "^0.10.3",
        "tsconfig-paths": "^4.2.0",
        "typescript": "^5.9.3"
    }
}
